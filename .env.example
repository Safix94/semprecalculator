# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Token hashing secret (generate with: openssl rand -hex 32)
# Keep this stable between sending and opening supplier invite links.
TOKEN_HASH_SECRET=your-random-secret-here

# Brevo (email)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@sempre.com
BREVO_SENDER_NAME=Sempre

# Pricing team notification recipients (single email or comma-separated list)
PRICING_TEAM_EMAIL=pricing@sempre.be

# App URL (for magic links in emails)
# Must match the environment where suppliers open the link.
NEXT_PUBLIC_APP_URL=http://localhost:3000
